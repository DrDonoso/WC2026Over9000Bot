# Required — Telegram Bot credentials (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Required — football-data.org API key
FOOTBALL_DATA_API_KEY=your-api-key-here

# Required — Telegram group/channel ID for live goal notifications
TELEGRAM_GROUP_ID=-100XXXXXXXXXX

# Optional — Override defaults
# PREDICTIONS_PATH=/app/data/predictions.yml
# TONGO_USERS_PATH=/app/data/TongoUsers.yml   # config de /tongo: frases globales (phrases:) + por persona (users:); default: data/TongoUsers.yml
# COMPETITION_CODE=WC
# TIMEZONE=Europe/Madrid
# FOOTBALL_CACHE_TTL=60
# FOOTBALL_DAY_START_HOUR=9
# PHOTO_BASE_URL=http://victorsaez.cat
# TONGO_GIFS_DIR=        # override the folder scanned for /tongo GIFs (default: data/tongo_gifs/)

# Optional — OpenAI-compatible AI (self-hosted LiteLLM) for the daily 9AM update.
# Set ALL THREE to enable the feature; leave unset to keep it disabled.
# OPENAI_API_KEY=your-litellm-key
# OPENAI_BASE_URL=https://your-litellm-host/v1
# OPENAI_MODEL=your-model-name
# DAILY_UPDATE_HOUR=9

# Optional — Group chat features (picante random replies + revive inactive users).
# Both features require the OPENAI_* vars above to be fully set, and Telegram privacy mode
# to be DISABLED so the bot receives all group messages (see README "Telegram privacy mode").
# Default: both disabled (0).
# CHAT_PICANTE_ENABLED=0          # Spicy random replies in group chats
# CHAT_REVIVE_ENABLED=0           # Revive inactive group members
# CHAT_BUFFER_SIZE=30             # Recent messages kept in memory for AI context
# PICANTE_PROBABILITY=0.20        # Probability of replying (~1 in 5 eligible messages)
# PICANTE_COOLDOWN_SECONDS=300    # Minimum seconds between spicy replies
# PICANTE_MAX_PER_DAY=30          # Hard daily cap on spicy replies
# PICANTE_MIN_BUFFER=5            # Don't fire until buffer has >= N messages
# PICANTE_TEMPERATURE=0.9         # LLM temperature for spicy replies
# REVIVE_CHECK_INTERVAL_SECONDS=14400   # Base interval; actually randomized ±REVIVE_JITTER_SECONDS (self-rescheduling, ≈4h ± up to 45m)
# REVIVE_JITTER_SECONDS=2700      # Randomize the check interval ±this many seconds (±45 min); prevents thundering herd
# REVIVE_INACTIVE_DAYS=3          # Days silent = considered inactive
# REVIVE_MENTION_COOLDOWN_DAYS=2  # Don't mention same user within N days
# REVIVE_QUIET_START_HOUR=23      # No revive mentions at/after this LOCAL hour (uses TIMEZONE)
# REVIVE_QUIET_END_HOUR=6         # ...until this LOCAL hour (wraps midnight; 23:00–06:00 local = nightly quiet window)
# REVIVE_TEMPERATURE=0.8          # LLM temperature for revive messages

# Optional — Daily 'rich' image evolution via gpt-image-2 (LiteLLM at 11:00 by default).
# Image is sent to TELEGRAM_GROUP_ID.
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_API_KEY=your-litellm-key (if empty, falls back to OPENAI_API_KEY)
# OPENAI_IMAGE_BASE_URL=https://your-litellm-host/v1 (if empty, falls back to OPENAI_BASE_URL)
# RICH_IMAGE_HOUR=0 (24h local time; default 0 = 00:00 / midnight)

# Optional — Beloved teams (comma-separated football-data TLAs).
# The bot displays a ❤️ next to these teams' flags in all outputs (standings, match previews, etc).
# Default: Panamá (PAN), Uzbekistán (UZB), Curaçao (CUW).
# BELOVED_TEAMS=PAN,UZB,CUW

# Optional — Mark matches that are broadcast on TVE (La1/Teledeporte) with 📺 in /hoy, /siguiente, and the daily update.
# Set to 0 to disable if the undocumented RTVE API breaks mid-tournament; default 1 = enabled.
# TVE_ENABLED=1

# Optional — /elecciones display mode: "text" (default) or "image" (PIL knockout matrix).
# CHOICES_TYPE=text

# STATE_DIR — where the bot persists the daily porra snapshot.
# Set in docker-compose.yml to /app/state via named volume; override only if you know what you're doing.
